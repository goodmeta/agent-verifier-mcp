{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.goodmeta/agent-verifier-mcp",
  "description": "Spending limits for AI agents. Create budgets, enforce limits, track spend across services.",
  "repository": {
    "url": "https://github.com/goodmeta/agent-verifier-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@goodmeta/agent-verifier-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "VERIFIER_API_KEY",
          "description": "API key for the verifier service. Get one free at verifier.goodmeta.co/setup/merchants",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "VERIFIER_URL",
          "description": "Verifier service URL (default: https://verifier.goodmeta.co)",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
